# Copy this file to .streamlit/secrets.toml for local dev (never commit secrets.toml)
# For Streamlit Cloud: paste these into App Settings > Secrets

[credentials.usernames.admin]
email = "admin@yourcompany.com"
name = "Admin User"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role = "admin"

[credentials.usernames.manager]
email = "manager@yourcompany.com"
name = "Inventory Manager"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role = "manager"

[cookie]
expiry_days = 7
key = "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY"
name = "pm_inventory_auth"
